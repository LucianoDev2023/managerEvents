rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
   // ✅ Permitir leitura pública da configuração de versão
    match /config/appVersion {
      allow read: if true;  // Todos podem ler
      allow write: if false; // Apenas via console/admin
    }

    // =========================================================
    // Helpers globais
    // =========================================================
    function signedIn() {
      return request.auth != null;
    }

    // docId padrão: `${uid}_${eventId}`
    function guestDocId(uid, eventId) {
      return uid + "_" + eventId;
    }

    // Rate limiting: evitar gravações consecutivas rápidas (< 1s)
    function isNotThrottled() {
      return resource == null 
        || !('updatedAt' in resource.data) 
        || request.time > resource.data.updatedAt + duration.value(1, 's');
    }

    function eventExists(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId));
    }

    function eventDocById(eventId) {
      return get(/databases/$(database)/documents/events/$(eventId));
    }

    function isOwnerOfEventId(eventId) {
      return signedIn()
        && eventExists(eventId)
        && eventDocById(eventId).data.userId == request.auth.uid;
    }

    function isSubAdminOfEventId(eventId) {
      return signedIn()
        && eventExists(eventId)
        && (
          (
            (eventDocById(eventId).data.subAdminsByUid is map)
            && (eventDocById(eventId).data.subAdminsByUid[request.auth.uid] != null)
          )
          || (
            (eventDocById(eventId).data.subAdminUids is list)
            && (request.auth.uid in eventDocById(eventId).data.subAdminUids)
          )
        );
    }

    function isParticipantOfEventId(eventId) {
      return signedIn()
        && exists(/databases/$(database)/documents/guestParticipations/$(guestDocId(request.auth.uid, eventId)));
    }

    function isShareKeyPossessor(eventId) {
      // shareKey válida: existe E não expirou
      let shareKey = eventDocById(eventId).data.get('shareKey', null);
      let keyDoc = shareKey != null
        ? get(/databases/$(database)/documents/eventShareKeys/$(shareKey))
        : null;
      return signedIn()
        && shareKey != null
        && exists(/databases/$(database)/documents/eventShareKeys/$(shareKey))
        && keyDoc.data.get('expiresAt', null) != null
        && keyDoc.data.expiresAt > request.time;
    }

    function canReadEventTree(eventId) {
      // Usamos exists para evitar ciclos de get()
      return (exists(/databases/$(database)/documents/events/$(eventId)) && get(/databases/$(database)/documents/events/$(eventId)).data.get('isPublic', false) == true)
        || isOwnerOfEventId(eventId) 
        || isSubAdminOfEventId(eventId) 
        || isParticipantOfEventId(eventId);
    }

    function canManageEventTree(eventId) {
      // admin (owner ou subadmin)
      return isOwnerOfEventId(eventId) || isSubAdminOfEventId(eventId);
    }

    // Usuário registrado (não-anônimo): existe doc em /users/{uid}
    function isRegisteredUser(uid) {
      return signedIn() && exists(/databases/$(database)/documents/users/$(uid));
    }

    function isValidComment() {
      return request.resource.data.uid is string
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 50
        && (
          !('name' in request.resource.data)
          || request.resource.data.name is string
        );
    }

    // =========================================================
    // EVENT SHARE KEYS (shareKey -> eventId)
    // =========================================================
    match /eventShareKeys/{shareKey} {
      // ✅ permitir GET de uma chave específica (resolver shareKey -> eventId)
      allow get: if true;

      // ❌ bloquear enumeração
      allow list: if false;

      // ✅ criar: apenas dono do evento ou subadmin
      allow create: if signedIn()
        && request.resource.data.eventId is string
        && eventExists(request.resource.data.eventId)
        && (
           eventDocById(request.resource.data.eventId).data.userId == request.auth.uid
           || (request.auth.uid in eventDocById(request.resource.data.eventId).data.get('subAdminUids', []))
        );

      // ✅ update: apenas dono ou subadmin, eventId imutável
      allow update: if signedIn()
        && request.resource.data.eventId is string
        && eventExists(request.resource.data.eventId)
        && (
           eventDocById(request.resource.data.eventId).data.userId == request.auth.uid
           || (request.auth.uid in eventDocById(request.resource.data.eventId).data.get('subAdminUids', []))
        )
        && (
          !(resource.data.keys().hasAny(['eventId'])) ||
          request.resource.data.eventId == resource.data.eventId
        );

      // ✅ delete: apenas dono do evento (ou quem gerencia)
      allow delete: if signedIn() && canManageEventTree(resource.data.get('eventId', ''));
    }

    // =========================================================
    // EVENT INVITE SUMMARIES (preview reduzido por shareKey)
    // =========================================================
    match /eventInviteSummaries/{shareKey} {

      // ✅ leitura do preview: qualquer pessoa com a chave pode ver (público)
      allow get: if true;

      // ❌ bloqueia enumeração (não permitir varredura de convites)
      allow list: if false;

      function keyExists() {
        return exists(/databases/$(database)/documents/eventShareKeys/$(shareKey));
      }

      function keyDoc() {
        return get(/databases/$(database)/documents/eventShareKeys/$(shareKey));
      }

      function eventIdFromKey() {
        return keyDoc().data.eventId;
      }

      // ✅ create: permite se for o dono do evento (evita race condition com keyExists)
      allow create: if signedIn()
        && request.resource.data.v == 1
        && request.resource.data.eventId is string
        && isOwnerOfEventId(request.resource.data.eventId);

      // ✅ update: somente owner ou subadmin do evento vinculado
      allow update: if signedIn()
        && keyExists()
        && (
           eventDocById(eventIdFromKey()).data.userId == request.auth.uid
           || (request.auth.uid in eventDocById(eventIdFromKey()).data.get('subAdminUids', []))
        );

      // ✅ delete: somente owner do evento vinculado (ou quem gerencia)
      allow delete: if signedIn() && canManageEventTree(resource.data.get('eventId', ''));
    }

    // =========================================================
    // EVENTS
    // =========================================================
    match /events/{eventId} {

      function isValidEvent() {
        return request.resource.data.userId is string
          && request.resource.data.title is string
          && (
            !('isPublic' in request.resource.data) 
            || request.resource.data.isPublic is bool
          )
          // Limite de 10 tarefas por evento (evitar doc > 1MB e abuso)
          && (
            !('tasks' in request.resource.data)
            || (request.resource.data.tasks is list && request.resource.data.tasks.size() <= 10)
          );
      }

      // NOVO: helpers locais usam resource.data (do próprio evento sendo avaliado)
      function isOwner() {
        return signedIn() && resource.data.userId == request.auth.uid;
      }

      function isSubAdmin() {
        let d = resource.data;
        return signedIn() && (
          (d.subAdminsByUid is map && d.subAdminsByUid[request.auth.uid] != null)
          || (d.subAdminUids is list && request.auth.uid in d.subAdminUids)
        );
      }

      function canRead() {
        return (resource.data.get('isPublic', false) == true)
          || isOwner() 
          || isSubAdmin() 
          || isParticipantOfEventId(eventId)
          || (
            // isShareKeyPossessor manual aqui para evitar get() recursivo
            resource.data.get('shareKey', null) != null 
            && exists(/databases/$(database)/documents/eventShareKeys/$(resource.data.shareKey))
          );
      }

      function canManage() {
        return isOwner() || isSubAdmin();
      }

      // Regras do Documento do Evento
      // LEITURA: get usa canRead() (inclui participantes e shareKey).
      // list usa regra mais restrita: apenas campos do próprio documento,
      // sem cross-document reads que são caros/não confiáveis em queries.
      allow get: if canRead();
      
      allow list: if signedIn() && (
        // Dono do evento (client query: where('userId', '==', uid))
        resource.data.userId == request.auth.uid
        // Subadmin (client query: where('subAdminUids', 'array-contains', uid))
        || isSubAdmin()
        // Evento público
        || resource.data.get('isPublic', false) == true
      );

      allow create: if signedIn() 
        && request.resource.data.userId == request.auth.uid
        && isValidEvent();
      
      allow update: if signedIn()
        && canManage()
        && request.resource.data.userId == resource.data.userId
        && isNotThrottled()
        && isValidEvent();

      allow delete: if signedIn() && isOwner();

      // -------------------------
      // Subcoleções (usam get() explícito via global helpers, pois 'resource' aqui muda de contexto)
      // -------------------------
      match /programs/{programId} {
        allow read: if canReadEventTree(eventId);
        allow create, update, delete: if canManageEventTree(eventId);

        match /activities/{activityId} {
          allow read: if canReadEventTree(eventId);
          allow create, update, delete: if canManageEventTree(eventId);

          match /photos/{photoId} {
            allow read: if canReadEventTree(eventId);

            allow create: if canManageEventTree(eventId)
              && request.resource.data.uri is string
              && request.resource.data.publicId is string
              && request.resource.data.createdByUid == request.auth.uid;

            allow update: if signedIn()
              && (resource.data.createdByUid == request.auth.uid || canManageEventTree(eventId))
              && request.resource.data.createdByUid == resource.data.createdByUid
              && request.resource.data.uri == resource.data.uri
              && request.resource.data.publicId == resource.data.publicId;

            allow delete: if signedIn() && (
              resource.data.createdByUid == request.auth.uid ||
              canManageEventTree(eventId)
            );

            match /comments/{commentId} {
              allow read: if canReadEventTree(eventId);
              allow create: if canReadEventTree(eventId) 
                && request.resource.data.uid == request.auth.uid
                && isNotThrottled()
                && isValidComment();
              allow delete: if signedIn() && (
                resource.data.get('uid', resource.data.get('userId', '')) == request.auth.uid ||
                canManageEventTree(eventId)
              );
            }
          }
        }
      }

      match /notes/{noteId} {
        // Somente admins do evento podem ler/escrever anotações do organizador
        allow read: if canManageEventTree(eventId);
        // Limite de 10 campos por documento de nota (evitar crescimento ilimitado do doc)
        allow write: if canManageEventTree(eventId)
          && (
            !('fields' in request.resource.data)
            || (request.resource.data.fields is list && request.resource.data.fields.size() <= 10)
          );
      }
    }

    // GUEST PARTICIPATIONS
    // =========================================================
    match /guestParticipations/{docId} {
      
      function isParticipationOwner() {
        return signedIn() && resource != null && resource.data.userId == request.auth.uid;
      }
      
      // Helper robusto para checar se o usuário logado é admin do evento vinculado a este doc
      function canManageThisParticipation() {
        let eid = resource != null ? resource.data.get('eventId', null) : null;
        return eid != null && canManageEventTree(eid);
      }

      function isValidParticipation() {
        return request.resource.data.eventId is string
          && request.resource.data.userId is string
          && (
            !('mode' in request.resource.data) 
            || (request.resource.data.mode == 'confirmado' || request.resource.data.mode == 'acompanhando')
          );
      }

      // LEITURA: Apenas participantes confirmados ou administradores podem ver os dados de participação.
      allow get: if signedIn() && (
        isParticipationOwner()
        || (resource != null && resource.data.get('eventId', null) != null && canReadEventTree(resource.data.eventId))
      );
      
      allow list: if signedIn() && (
        (isParticipationOwner())
        || (resource.data.get('eventId', null) != null && canReadEventTree(resource.data.eventId))
      );

      // CRIAÇÃO
      allow create: if signedIn() && (
        // Opção 1: User criando pra si mesmo (padrão: docId = uid_eventId)
        (
          docId == (request.auth.uid + "_" + request.resource.data.eventId)
          && request.resource.data.userId == request.auth.uid
          && eventExists(request.resource.data.eventId)
        )
        // Opção 2: Admin do evento criando convidado manual.
        // ⚠️ Convidados manuais usam docId = manual_{ts}_{rand} e userId = manual_{ts}.
        // Isso é intencional: não possuem UID real do Firebase Auth.
        // A segurança é garantida por canManageEventTree (dono/subadmin do evento).
        || (
          canManageEventTree(request.resource.data.eventId)
        )
      ) && isValidParticipation();

      // ATUALIZAÇÃO
      allow update: if signedIn() && (
        // Dono da participação pode editar campos básicos
        (
          isParticipationOwner() 
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.eventId == resource.data.eventId
        )
        // Admin do evento pode editar
        || canManageThisParticipation()
      ) && isValidParticipation();

      // DELEÇÃO
      allow delete: if signedIn() && (
        isParticipationOwner() || canManageThisParticipation()
      );
    }


    // =========================================================
    // USERS
    // =========================================================
    match /users/{uid} {
      allow read, write: if signedIn() && uid == request.auth.uid;
    }

    match /publicUsers/{uid} {
      allow get: if signedIn();
      allow list: if false;
      allow write: if signedIn() && uid == request.auth.uid;
    }
    // =========================================================
    // Default deny
    // =========================================================
    match /{document=**} {
      allow read, write: if false;
    }

    match /reports/{reportId} {
      function eventDoc(eid) {
        return get(/databases/$(database)/documents/events/$(eid));
      }

      function canManageReport(eid) {
        let d = eventDoc(eid).data;
        return d.userId == request.auth.uid
          || (d.get('subAdminsByUid', {})[request.auth.uid] == 'Super Admin');
      }

      // Apenas participantes autorizados do evento podem criar denúncias
      allow create: if request.auth != null 
        && request.resource.data.reportedBy == request.auth.uid
        && request.resource.data.eventId != null
        && (
          eventDoc(request.resource.data.eventId).data.userId == request.auth.uid
          || (eventDoc(request.resource.data.eventId).data.get('subAdminsByUid', {})[request.auth.uid] in ['Super Admin', 'Admin parcial'])
          || exists(/databases/$(database)/documents/guestParticipations/$(request.auth.uid + '_' + request.resource.data.eventId))
        );
      
      // Apenas admins dos eventos podem ler e modificar denúncias
      allow read, update, delete: if request.auth != null && canManageReport(resource.data.eventId);
    }

    // ✅ Nova regra para fotos bloqueadas
    match /users/{userId}/blockedPhotos/{photoId} {
      allow read: if request.auth.uid == userId;
      allow write: if request.auth.uid == userId;
    }

  }
}
